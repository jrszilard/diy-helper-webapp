# ── Required ──────────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Brave Search API
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_your-subscription-webhook-secret
STRIPE_PAYMENT_WEBHOOK_SECRET=whsec_your-payment-webhook-secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your-connect-webhook-secret

# App / Site URL (used for CORS, Stripe redirects, metadata)
NEXT_PUBLIC_SITE_URL=https://fixerator.com

# Cron job protection (Vercel Cron sends this as Authorization header)
CRON_SECRET=generate-a-secure-random-string

# ── Recommended for Production ───────────────────────────────────────────────

# Upstash Redis (required for production — in-memory rate limiting does not
# persist across serverless cold starts)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Resend (transactional emails for notifications)
RESEND_API_KEY=re_your-resend-api-key
# Must match the domain verified in Resend
EMAIL_DOMAIN=fixerator.com

# Sentry error monitoring (B2). Wiring is dormant until the DSN is set.
# Public DSN — safe to expose; events are tunneled through /monitoring so the
# CSP connect-src 'self' covers them.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXX.ingest.sentry.io/XXXX
# Build-time source-map upload (readable stack traces). Optional but recommended.
# SENTRY_ORG and SENTRY_PROJECT are slugs; SENTRY_AUTH_TOKEN is a build secret
# (set in Vercel only, never commit). Source-map upload is skipped if absent.
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_your-build-token

# ── Beta Mode ────────────────────────────────────────────────────────────────
# Bypasses all real Stripe charges, removes usage limits, shows beta banner + feedback widget
# NEXT_PUBLIC_BETA_MODE=true

# Shared login password for the seeded concierge expert accounts
# (scripts/seed-concierge-experts.mjs). Use a strong random value.
# SEED_EXPERT_PASSWORD=generate-a-strong-password

# ── Optional Overrides (all have sensible defaults) ──────────────────────────

# Anthropic model and token limit
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=4096

# Rate limits (max bucket size / refill tokens-per-second)
# RATE_LIMIT_CHAT_MAX=10
# RATE_LIMIT_CHAT_REFILL=0.1667
# RATE_LIMIT_SEARCH_STORES_MAX=20
# RATE_LIMIT_SEARCH_STORES_REFILL=0.3333
# RATE_LIMIT_EXTRACT_MAX=10
# RATE_LIMIT_EXTRACT_REFILL=0.1667
# RATE_LIMIT_CONVERSATIONS_MAX=30
# RATE_LIMIT_CONVERSATIONS_REFILL=0.5

# CORS (comma-separated origins — production domain is auto-included via NEXT_PUBLIC_SITE_URL)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# Store search tuning
# STORE_SEARCH_CONCURRENCY=3
# STORE_SEARCH_CHUNK_DELAY_MS=500

# Streaming tuning
# STREAM_CHUNK_SIZE=50
# STREAM_CHUNK_DELAY_MS=15

# Conversation pruning thresholds
# PRUNE_MAX_TOTAL_CHARS=80000
# PRUNE_KEEP_FIRST=2
# PRUNE_KEEP_LAST=10
# PRUNE_MAX_SINGLE_MSG_CHARS=8000

# Q&A Marketplace Timing
# QA_CLAIM_EXPIRY_HOURS=2
# QA_AUTO_ACCEPT_HOURS=24
# QA_PAYMENT_TEST_MODE=true

# ── Advisor Strategy ───────────────────────────────────────────────────────
# Mode: "off" (no review), "beta" (Anthropic advisor API), "custom" (our review loop)
# ADVISOR_MODE=off

# Beta mode config (used when ADVISOR_MODE=beta)
# ADVISOR_EXECUTOR_QUICK=claude-haiku-4-5-20251001
# ADVISOR_EXECUTOR_TROUBLESHOOT=claude-sonnet-4-6
# ADVISOR_EXECUTOR_MID=claude-sonnet-4-6
# ADVISOR_EXECUTOR_FULL=claude-sonnet-4-6
# ADVISOR_MODEL_TROUBLESHOOT=claude-opus-4-6
# ADVISOR_MODEL_MID=claude-opus-4-6
# ADVISOR_MODEL_FULL=claude-opus-4-6
# ADVISOR_MAX_USES_TROUBLESHOOT=2
# ADVISOR_MAX_USES_MID=1
# ADVISOR_MAX_USES_FULL=3

# Custom mode config (used when ADVISOR_MODE=custom)
# ADVISOR_CUSTOM_MODEL=claude-haiku-4-5-20251001
# ADVISOR_CUSTOM_PROVIDER=anthropic
# ADVISOR_CUSTOM_MAX_ITERATIONS=2
# ADVISOR_CUSTOM_EARLY_STOP=true

# Safety keywords (shared by both beta and custom modes)
# ADVISOR_SAFETY_KEYWORDS=electrical panel,breaker box,gas line,...
# ADVISOR_SAFETY_BOOST_USES=1
